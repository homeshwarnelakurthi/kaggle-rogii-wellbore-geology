mns and handle missing Gamma Ray data\n    if 'GR' not in df.columns:\n        df['GR'] = 0.0\n    else:\n        df['GR'] = df['GR'].fillna(method='ffill').fillna(method='bfill').fillna(0)\n        \n    # Return numpy arrays for tensor conversion\n    if target_col in df.columns:\n        return df[feature_cols].values, df[target_col].values\n    return df[feature_cols].values, None\n\n# 4. Ingestion and Normalization Loop\nall_features = []\nall_targets = []\nwell_lengths = []\n\nprint(\"Extracting sequences and spatial derivatives...\")\nsubset_files = train_files[:500] \n\nfor file in tqdm(subset_files):\n    x, y = process_well_file(file)\n    all_features.append(x)\n    all_targets.append(y)\n    well_lengths.append(len(x))\n\n# Fit standard scaler on the combined feature space\nprint(\"Applying Standard Scaling for Neural Network convergence...\")\nscaler = StandardScaler()\ncombined_features = np.vstack(all_features)\nscaler.fit(combined_features)\n\nscaled_features = [scaler.transform(x) for x in all_features]\n\n# 5. Tensor Conversion\ntensors_x = [torch.tensor(x, dtype=torch.float32) for x in scaled_features]\ntensors_y = [torch.tensor(y, dtype=torch.float32) for y in all_targets]\n\nprint(\"\\n--- Phase 2 Tensor Compilation Complete ---\")\nprint(f\"Processed Wells: {len(tensors_x)}\")\nprint(f\"Sample Feature Tensor Shape (Well 0): {tensors_x}\")","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true,"execution":{"iopub.status.busy":"2026-05-19T19:52:11.945988Z","iopub.execute_input":"2026-05-19T19:52:11.946789Z","iopub.status.idle":"2026-05-19T19:52:22.583698Z","shell.execute_reply.started":"2026-05-19T19:52:11.946757Z","shell.execute_reply":"2026-05-19T19:52:22.582637Z"}},"outputs":[{"name":"stdout","text":"Computation Device: cuda\nExtracting sequences and spatial derivatives...\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"  0%|          | 0