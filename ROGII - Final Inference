    "import os\n",
    "import glob\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import torch\n",
    "import lightgbm as lgb\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "import joblib\n",
    "\n",
    "# 1. Architecture Definition\n",
    "class GeologyWaveNet(nn.Module):\n",
    "    def __init__(self, in_channels, hidden_channels=64, out_channels=1, num_layers=5):\n",
    "        super(GeologyWaveNet, self).__init__()\n",
    "        self.initial_conv = nn.Conv1d(in_channels, hidden_channels, kernel_size=1)\n",
    "        self.dilated_convs = nn.ModuleList()\n",
    "        for i in range(num_layers):\n",
    "            dilation = 2 ** i\n",
    "            padding = dilation \n",
    "            self.dilated_convs.append(\n",
    "                nn.Conv1d(hidden_channels, hidden_channels, kernel_size=3, \n",
    "                          padding=padding, dilation=dilation)\n",
    "            )\n",
    "        self.final_conv = nn.Conv1d(hidden_channels, out_channels, kernel_size=1)\n",
    "        \n",
    "    def forward(self, x):\n",
    "        x = self.initial_conv(x)\n",
    "        for conv in self.dilated_convs:\n",
    "            residual = x\n",
    "            x = F.relu(conv(x))\n",
    "            x = x + residual\n",
    "        out = self.final_conv(x)\n",
    "        return out\n",
    "\n",
    "# 2. Setup\n",
    "device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "scaler_path = glob.glob('/kaggle/input/**/scaler.pkl', recursive=True)[0]\n",
    "cnn_path = glob.glob('/kaggle/input/**/geology_wavenet_weights.pth', recursive=True)[0]\n",
    "lgbm_paths = glob.glob('/kaggle/input/**/lgbm_enriched_fold_*.txt', recursive=True)\n",
    "\n",
    "scaler = joblib.load(scaler_path)\n",
    "model_cnn = GeologyWaveNet(in_channels=5).to(device)\n",
    "model_cnn.load_state_dict(torch.load(cnn_path, map_location=device))\n",
    "model_cnn.eval()\n",
    "lgb_models = [lgb.Booster(model_file=path) for path in sorted(lgbm_paths)]\n",
    "\n",
    "# 3. Inference Loop\n",
    "test_files = glob.glob('/kaggle/input/competitions/rogii-wellbore-geology-prediction/test/*.csv')\n",
    "sample_sub = pd.read_csv('/kaggle/input/competitions/rogii-wellbore-geology-prediction/sample_submission.csv')\n",
    "submission_list = []\n",
    "\n",
    "print(f\"Processing {len(test_files)} files...\")\n",
    "\n",
    "for file in test_files:\n",
    "    df = pd.read_csv(file)\n",
    "    \n",
    "    # --- Critical: ID Handling ---\n",
    "    # Check if 'id' exists in the test file. If yes, USE IT. \n",
    "    # If not, we fall back to index, but this is likely why you have a mismatch.\n",
    "    if 'id' not in df.columns:\n",
    "        well_id = os.path.basename(file).split('__')[0]\n",
    "        df['id'] = well_id + '_' + df.index.astype(str)\n",
    "        \n",
    "    # --- Feature Engineering ---\n",
    "    if 'MD' not in df.columns: df['MD'] = np.arange(len(df))\n",
    "    df = df.sort_values('MD').reset_index(drop=True)\n",
    "    df['MD_diff'] = df['MD'].diff().fillna(0)\n",
    "    for col in ['X', 'Y', 'Z']:\n",
    "        df[f'{col}_diff'] = df[col].diff().fillna(0) if col in df.columns else 0.0\n",
    "    \n",
    "    features = df[['GR', 'MD_diff', 'X_diff', 'Y_diff', 'Z_diff']]\n",
    "    \n",
    "    # --- CNN + LGBM Prediction ---\n",
    "    x_scaled = scaler.transform(features)\n",
    "    x_tensor = torch.tensor(x_scaled, dtype=torch.float32).unsqueeze(0).transpose(1, 2).to(device)\n",
    "    \n",
    "    with torch.no_grad():\n",
    "        emb = model_cnn.initial_conv(x_tensor)\n",
    "        for conv in model_cnn.dilated_convs:\n",
    "            emb = F.relu(conv(emb))\n",
    "        embedding = emb.mean(dim=2).cpu().numpy()\n",
    "        \n",
    "    combined_data = np.hstack([x_scaled, np.tile(embedding, (len(df), 1))])\n",
    "    preds = np.mean([m.predict(combined_data) for m in lgb_models], axis=0)\n",
    "    \n",
    "    # Save predictions with the actual 'id' column\n",
    "    submission_rows = pd.DataFrame({'id': df['id'], 'tvt': preds})\n",
    "    submission_list.append(submission_rows)\n",
    "\n",
    "# 4. Final Merge (Fixed to handle duplicates)\n",
    "all_preds = pd.concat(submission_list, ignore_index=True)\n",
    "\n",
    "# CRITICAL: Remove any duplicate IDs from your predictions before merging\n",
    "all_preds = all_preds.drop_duplicates(subset=['id'], keep='first')\n",
    "\n",
    "# Now perform the merge. Since 'sample_sub' is the source of truth, \n",
    "# this will result in exactly 14,151 rows.\n",
    "final_submission = sample_sub[['id']].merge(all_preds, on='id', how='inner')\n",
    "\n",
    "# Final sanity check to fill missing values\n",
    "final_submission['tvt'] = final_submission['tvt'].fillna(0)\n",
    "\n",
    "# Final Save\n",
    "final_submission.to_csv('submission.csv', index=False)\n",
    "print(f\"Final submission rows: {len(final_submission)}\")"
   ]
