    "import gc\n",
    "import numpy as np\n",
    "import lightgbm as lgb\n",
    "from sklearn.model_selection import GroupKFold\n",
    "from sklearn.metrics import mean_squared_error\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# 1. Define Features and Target\n",
    "target = 'TVT'\n",
    "drop_cols = [target, 'Well_ID', 'Geology', 'TVT_input'] # Dropping highly sparse TVT_input for the initial baseline\n",
    "features = [c for c in train_df.columns if c not in drop_cols]\n",
    "\n",
    "print(f\"Target variable: {target}\")\n",
    "print(f\"Features selected for modeling ({len(features)}): {features}\\n\")\n",
    "\n",
    "# 2. Initialize Validation Framework\n",
    "n_splits = 5\n",
    "gkf = GroupKFold(n_splits=n_splits)\n",
    "oof_preds = np.zeros(len(train_df))\n",
    "\n",
    "# 3. Define LightGBM Hyperparameters\n",
    "lgb_params = {\n",
    "    'objective': 'regression',\n",
    "    'metric': 'rmse',\n",
    "    'boosting_type': 'gbdt',\n",
    "    'learning_rate': 0.05,\n",
    "    'num_leaves': 127,\n",
    "    'max_depth': 10,\n",
    "    'feature_fraction': 0.8,\n",
    "    'subsample': 0.8,\n",
    "    'random_state': 42,\n",
    "    'n_jobs': -1,\n",
    "    'verbose': -1\n",
    "}\n",
    "\n",
    "print(\"Initiating LightGBM GroupKFold Cross-Validation...\\n\")\n",
    "\n",
    "# 4. Training Loop\n",
    "for fold, (train_idx, valid_idx) in enumerate(gkf.split(train_df, groups=train_df['Well_ID'])):\n",
    "    print(f\"--- Fold {fold + 1}/{n_splits} ---\")\n",
    "    \n",
    "    # Isolate fold data\n",
    "    X_train, y_train = train_df[features].iloc[train_idx], train_df[target].iloc[train_idx]\n",
    "    X_valid, y_valid = train_df[features].iloc[valid_idx], train_df[target].iloc[valid_idx]\n",
    "    \n",
    "    # Construct optimized LightGBM Datasets\n",
    "    dtrain = lgb.Dataset(X_train, label=y_train)\n",
    "    dvalid = lgb.Dataset(X_valid, label=y_valid, reference=dtrain)\n",
    "    \n",
    "    # Train the model\n",
    "    model = lgb.train(\n",
    "        lgb_params,\n",
    "        dtrain,\n",
    "        num_boost_round=2000,\n",
    "        valid_sets=[dtrain, dvalid],\n",
    "        callbacks=[\n",
    "            lgb.early_stopping(stopping_rounds=150, verbose=False),\n",
    "            lgb.log_evaluation(period=250)\n",
    "        ]\n",
    "    )\n",
    "    \n",
    "    # Generate predictions and evaluate\n",
    "    valid_preds = model.predict(X_valid, num_iteration=model.best_iteration)\n",
    "    oof_preds[valid_idx] = valid_preds\n",
    "    \n",
    "    fold_rmse = np.sqrt(mean_squared_error(y_valid, valid_preds))\n",
    "    print(f\"Fold {fold + 1} RMSE: {fold_rmse:.4f}\\n\")\n",
    "    \n",
    "    # Serialize model weights for Phase 3 Inference\n",
    "    model.save_model(f'lgbm_baseline_fold_{fold+1}.txt')\n",
    "    \n",
    "    # Enforce memory cleanup\n",
    "    del X_train, y_train, X_valid, y_valid, dtrain, dvalid, model\n",
    "    gc.collect()\n",
    "\n",
    "# 5. Global Evaluation\n",
    "cv_rmse = np.sqrt(mean_squared_error(train_df[target], oof_preds))\n",
    "print(f\"====================================\")\n",
    "print(f\"Overall Cross-Validation RMSE: {cv_rmse:.4f}\")\n",
    "print(f\"====================================\")"
   ]
