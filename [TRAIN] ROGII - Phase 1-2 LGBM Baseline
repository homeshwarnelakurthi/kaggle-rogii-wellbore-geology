    "import pywt\n",
    "import numpy as np\n",
    "from scipy.interpolate import interp1d\n",
    "import lightgbm as lgb\n",
    "from sklearn.model_selection import GroupKFold\n",
    "from sklearn.metrics import mean_squared_error\n",
    "import gc\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "print(\"--- Initiating Version 2 Feature Engineering (DWT) ---\")\n",
    "\n",
    "# 1. Generate Discrete Wavelet Transforms for Gamma Ray\n",
    "dwt_approx = np.zeros(len(train_df))\n",
    "dwt_detail = np.zeros(len(train_df))\n",
    "\n",
    "# Process each well sequentially to maintain index alignment\n",
    "wells = train_df['Well_ID'].unique()\n",
    "for well in wells:\n",
    "    idx = train_df['Well_ID'] == well\n",
    "    signal = train_df.loc[idx, 'GR'].fillna(0).values\n",
    "    \n",
    "    if len(signal) > 4:\n",
    "        # Perform 1D Discrete Wavelet Transform (Daubechies 2)\n",
    "        cA, cD = pywt.dwt(signal, 'db2')\n",
    "        \n",
    "        # Interpolate coefficients back to the original sequence length\n",
    "        x_orig = np.linspace(0, 1, len(signal))\n",
    "        x_dwt = np.linspace(0, 1, len(cA))\n",
    "        \n",
    "        f_cA = interp1d(x_dwt, cA, kind='linear', fill_value='extrapolate')\n",
    "        f_cD = interp1d(x_dwt, cD, kind='linear', fill_value='extrapolate')\n",
    "        \n",
    "        dwt_approx[idx] = f_cA(x_orig)\n",
    "        dwt_detail[idx] = f_cD(x_orig)\n",
    "\n",
    "train_df['GR_dwt_approx'] = dwt_approx\n",
    "train_df['GR_dwt_detail'] = dwt_detail\n",
    "\n",
    "print(\"✅ DWT features successfully extracted.\")\n",
    "\n",
    "# 2. Define Version 2 Features (Dropping absolute coordinates)\n",
    "target = 'TVT'\n",
    "absolute_spatial_cols = ['X', 'Y', 'Z', 'MD', 'ANCC', 'ASTNU', 'ASTNL', 'EGFDU', 'EGFDL', 'BUDA']\n",
    "base_drop_cols = [target, 'Well_ID', 'Geology', 'TVT_input']\n",
    "\n",
    "# Combine drop lists\n",
    "drop_cols_v2 = base_drop_cols + absolute_spatial_cols\n",
    "features_v2 = [c for c in train_df.columns if c not in drop_cols_v2]\n",
    "\n",
    "print(f\"\\nFeatures selected for V2 modeling ({len(features_v2)}): {features_v2}\\n\")\n",
    "\n",
    "# 3. Initialize Validation Framework\n",
    "n_splits = 5\n",
    "gkf = GroupKFold(n_splits=n_splits)\n",
    "oof_preds_v2 = np.zeros(len(train_df))\n",
    "\n",
    "# 4. LightGBM V2 Training Loop\n",
    "lgb_params = {\n",
    "    'objective': 'regression',\n",
    "    'metric': 'rmse',\n",
    "    'boosting_type': 'gbdt',\n",
    "    'learning_rate': 0.05,\n",
    "    'num_leaves': 127,\n",
    "    'max_depth': 10,\n",
    "    'feature_fraction': 0.8,\n",
    "    'subsample': 0.8,\n",
    "    'random_state': 42,\n",
    "    'n_jobs': -1,\n",
    "    'verbose': -1\n",
    "}\n",
    "\n",
    "print(\"Initiating V2 LightGBM Cross-Validation...\")\n",
    "\n",
    "for fold, (train_idx, valid_idx) in enumerate(gkf.split(train_df, groups=train_df['Well_ID'])):\n",
    "    print(f\"--- Fold {fold + 1}/{n_splits} ---\")\n",
    "    \n",
    "    X_train, y_train = train_df[features_v2].iloc[train_idx], train_df[target].iloc[train_idx]\n",
    "    X_valid, y_valid = train_df[features_v2].iloc[valid_idx], train_df[target].iloc[valid_idx]\n",
    "    \n",
    "    dtrain = lgb.Dataset(X_train, label=y_train)\n",
    "    dvalid = lgb.Dataset(X_valid, label=y_valid, reference=dtrain)\n",
    "    \n",
    "    model = lgb.train(\n",
    "        lgb_params,\n",
    "        dtrain,\n",
    "        num_boost_round=2000,\n",
    "        valid_sets=[dtrain, dvalid],\n",
    "        callbacks=[\n",
    "            lgb.early_stopping(stopping_rounds=150, verbose=False),\n",
    "            lgb.log_evaluation(period=250)\n",
    "        ]\n",
    "    )\n",
    "    \n",
    "    valid_preds = model.predict(X_valid, num_iteration=model.best_iteration)\n",
    "    oof_preds_v2[valid_idx] = valid_preds\n",
    "    \n",
    "    fold_rmse = np.sqrt(mean_squared_error(y_valid, valid_preds))\n",
    "    print(f\"Fold {fold + 1} RMSE: {fold_rmse:.4f}\\n\")\n",
    "    \n",
    "    # Save V2 weights\n",
    "    model.save_model(f'lgbm_v2_fold_{fold+1}.txt')\n",
    "    \n",
    "    del X_train, y_train, X_valid, y_valid, dtrain, dvalid, model\n",
    "    gc.collect()\n",
    "\n",
    "# 5. Global Evaluation\n",
    "cv_rmse_v2 = np.sqrt(mean_squared_error(train_df[target], oof_preds_v2))\n",
    "print(f\"====================================\")\n",
    "print(f\"V2 Overall Cross-Validation RMSE: {cv_rmse_v2:.4f}\")\n",
    "print(f\"====================================\")"
   ]
