    "import os\n",
    "import glob\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "from tqdm.auto import tqdm\n",
    "from sklearn.preprocessing import LabelEncoder\n",
    "\n",
    "# 1. Define established paths\n",
    "DATA_DIR = '/kaggle/input/competitions/rogii-wellbore-geology-prediction'\n",
    "TRAIN_DIR = os.path.join(DATA_DIR, 'train')\n",
    "\n",
    "train_files = glob.glob(os.path.join(TRAIN_DIR, '*.csv'))\n",
    "print(f\"Initiating feature extraction across {len(train_files)} wellbores...\")\n",
    "\n",
    "# 2. Define the Feature Engineering Module\n",
    "def extract_spatial_features(df):\n",
    "    \"\"\"\n",
    "    Computes rate-of-change and rolling statistical features for well log data.\n",
    "    \"\"\"\n",
    "    df = df.copy()\n",
    "    \n",
    "    # Sort sequentially by Measured Depth (MD) to ensure time-series integrity\n",
    "    if 'MD' in df.columns:\n",
    "        df = df.sort_values('MD').reset_index(drop=True)\n",
    "        df['MD_diff'] = df['MD'].diff().fillna(0)\n",
    "        \n",
    "    # Gamma Ray (GR) Sequential Features\n",
    "    if 'GR' in df.columns:\n",
    "        # First and second derivatives (Edges and rapid shifts)\n",
    "        df['GR_diff1'] = df['GR'].diff().fillna(0)\n",
    "        df['GR_diff2'] = df['GR'].diff(2).fillna(0)\n",
    "        \n",
    "        # Smoothing and local variance\n",
    "        df['GR_roll_mean_5'] = df['GR'].rolling(window=5, min_periods=1).mean()\n",
    "        df['GR_roll_std_5'] = df['GR'].rolling(window=5, min_periods=1).std().fillna(0)\n",
    "        df['GR_roll_mean_20'] = df['GR'].rolling(window=20, min_periods=1).mean()\n",
    "        df['GR_roll_std_20'] = df['GR'].rolling(window=20, min_periods=1).std().fillna(0)\n",
    "        \n",
    "    # Spatial Kinematics (Trajectory changes)\n",
    "    for col in ['X', 'Y', 'Z']:\n",
    "        if col in df.columns:\n",
    "            df[f'{col}_diff'] = df[col].diff().fillna(0)\n",
    "            \n",
    "    return df\n",
    "\n",
    "# 3. Process the distributed dataset\n",
    "processed_dfs = []\n",
    "\n",
    "for file_path in tqdm(train_files, desc=\"Processing Train Data\"):\n",
    "    df = pd.read_csv(file_path)\n",
    "    \n",
    "    # Isolate the Well ID from the file nomenclature for GroupKFold\n",
    "    base_name = os.path.basename(file_path)\n",
    "    well_id = base_name.split('__')[0]\n",
    "    \n",
    "    # Inject engineered features\n",
    "    df = extract_spatial_features(df)\n",
    "    \n",
    "    # Append identifier\n",
    "    df['Well_ID'] = well_id\n",
    "    processed_dfs.append(df)\n",
    "\n",
    "# 4. Construct the unified tabular dataset\n",
    "train_df = pd.concat(processed_dfs, ignore_index=True)\n",
    "\n",
    "# 5. Categorical Encoding\n",
    "if 'Geology' in train_df.columns:\n",
    "    le = LabelEncoder()\n",
    "    train_df['Geology'] = train_df['Geology'].fillna('UNKNOWN_GEO')\n",
    "    train_df['Geology_encoded'] = le.fit_transform(train_df['Geology'])\n",
    "\n",
    "print(f\"\\nConsolidated Tabular Shape: {train_df.shape}\")\n",
    "print(\"\\nMissing values mapping (Target and Sparsity check):\")\n",
    "print(train_df.isnull().sum()[train_df.isnull().sum() > 0])"
   ]
